  "modules-center": ["hyprland/window"],
  "modules-right": ["hyprland/submap", "battery", "bluetooth", "tray", "custom/notification", "custom/power" ,"clock"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "format": "{name}",
    "on-scroll-up": "hyprctl dispatch workspace m-1 > /dev/null",
    "on-scroll-down": "hyprctl dispatch workspace m+1 > /dev/null",
    "on-click": "activate",
  },
  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": true
  },
